pkgbase = cutrail-git
	pkgdesc = Desktop video clipping utility for batch range exports
	pkgver = 0.1.0
	pkgrel = 2
	url = https://github.com/sabinmarcu/cutrail
	arch = x86_64
	license = MIT
	makedepends = git
	makedepends = proto-bin
	depends = electron37
	depends = glibc
	depends = gtk3
	depends = nss
	depends = libxss
	depends = libxtst
	depends = xdg-utils
	depends = at-spi2-core
	depends = libdrm
	depends = alsa-lib
	optdepends = ffmpeg: fallback ffmpeg binary for diagnostics and overrides
	provides = cutrail
	conflicts = cutrail
	conflicts = cutrail-bin
	options = !strip
	options = !debug
	source = cutrail::git+https://github.com/sabinmarcu/cutrail.git#branch=master
	sha256sums = SKIP

pkgname = cutrail-git
