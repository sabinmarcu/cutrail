{
  "servers": {
    "proto": {
      "type": "stdio",
      "command": "proto",
      "args": [
        "mcp"
      ],
      "cwd": "${workspaceFolder}"
    },
    "electron-debug": {
      "type": "stdio",
      "command": "yarn",
      "args": [
        "mcp:electron-debug"
      ],
      "cwd": "${workspaceFolder}"
    }
  }
}