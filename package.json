{
  "name": "cutrail",
  "version": "0.10.1",
  "description": "Desktop video clipping utility for batch range exports.",
  "homepage": "https://github.com/sabinmarcu/cutrail",
  "repository": {
    "type": "git",
    "url": "https://github.com/sabinmarcu/cutrail.git"
  },
  "author": "Sabin Marcu <sabinmarcu@gmail.com>",
  "license": "MIT",
  "main": "dist/electron/main/main.js",
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "~22",
      "onFail": "error"
    },
    "packageManager": {
      "name": "yarn",
      "version": "4.17.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "yarn build:node && concurrently -k -n renderer,node,electron \"yarn dev:renderer\" \"yarn build:node:watch\" \"yarn dev:electron\"",
    "dev:renderer": "vite --host localhost --port 5173 --strictPort",
    "dev:electron": "wait-on tcp:5173 file:dist/electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:node": "tsc -p tsconfig.node.build.json",
    "build:node:watch": "tsc -p tsconfig.node.build.json --watch",
    "build": "vite build",
    "package": "yarn build && yarn build:node && electron-builder --dir",
    "dist": "yarn build && yarn build:node && electron-builder",
    "dist:appimage": "yarn build && yarn build:node && electron-builder --linux AppImage",
    "dev:appimage": "yarn dist:appimage && bash -lc 'appimage=$(find dist -maxdepth 1 -type f -name \"*.AppImage\" | head -n 1); if [ -z \"$appimage\" ]; then echo \"No AppImage found in dist/.\"; exit 1; fi; chmod +x \"$appimage\"; \"$appimage\"'",
    "start": "yarn build && yarn build:node && electron .",
    "typecheck": "yarn typecheck:web && yarn typecheck:node",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:renderer": "yarn typecheck:web",
    "mcp:electron-debug": "yarn --cwd node_modules/electron-debug-mcp run build && node node_modules/electron-debug-mcp/build/index.js",
    "verify:ffmpeg": "node scripts/verify-ffmpeg-runtime.mjs",
    "check:tag-version": "node scripts/check-tag-version.mjs",
    "aur:printsrcinfo": "bash -lc 'for pkg in cutrail cutrail-bin cutrail-git; do (cd packaging/aur/$pkg && makepkg --printsrcinfo > .SRCINFO); done'",
    "aur:sync-toolchain": "node scripts/sync-aur-toolchain.mjs --write",
    "aur:check-toolchain": "node scripts/sync-aur-toolchain.mjs --check",
    "test": "vitest run",
    "lint": "yarn lint:eslint",
    "lint:eslint": "eslint --max-warnings=0 --no-error-on-unmatched-pattern --ignore-pattern \"**/*.d.ts\" \"src/**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}\" \"eslint.config.{js,cjs,mjs,ts,cts,mts}\" \"*.config.{js,cjs,mjs,ts,cts,mts}\" \".*rc.{js,cjs,mjs,ts,cts,mts}\"",
    "lint:fix": "eslint --fix --max-warnings=0 --no-error-on-unmatched-pattern --ignore-pattern \"**/*.d.ts\" \"src/**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}\" \"eslint.config.{js,cjs,mjs,ts,cts,mts}\" \"*.config.{js,cjs,mjs,ts,cts,mts}\" \".*rc.{js,cjs,mjs,ts,cts,mts}\"",
    "lint:staged": "lint-staged --config lint-staged.config.mjs"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@sabinmarcu/theme": "^1.2.0",
    "@vanilla-extract/css": "^1.21.1",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/recipes": "^0.5.7",
    "electron-updater": "^6.6.2",
    "jotai": "^2.20.1",
    "lucide-react": "^0.469.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "ts-deepmerge": "^8.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.22.0",
    "@sabinmarcu/eslint-config": "^3.4.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/types": "^8.0.0",
    "@vanilla-extract/vite-plugin": "^5.2.3",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.6",
    "electron-builder": "^24.13.3",
    "electron-debug-mcp": "github:amafjarkasi/electron-mcp-server",
    "eslint": "^9.39.4",
    "eslint-plugin-expect-type": "~0.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.sabinmarcu.cutrail",
    "productName": "Cutrail",
    "publish": [
      {
        "provider": "github",
        "owner": "sabinmarcu",
        "repo": "cutrail"
      }
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*"
    ],
    "files": [
      "dist/renderer/**/*",
      "dist/electron/**/*",
      "src/assets/**/*",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "directories": {
      "buildResources": "src/assets/icons"
    },
    "mac": {
      "icon": "src/assets/icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "src/assets/icons/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "icon": "src/assets/icons/icon.png",
      "maintainer": "Sabin Marcu <sabinmarcu@gmail.com>",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    }
  }
}
