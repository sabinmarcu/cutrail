{
  "name": "cutrail",
  "license": "MIT",
  "main": "src/main/main.cjs",
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently -k -n renderer,electron \"yarn dev:renderer\" \"yarn dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build",
    "start": "electron .",
    "test": "vitest run",
    "lint": "eslint --max-warnings=0 --no-error-on-unmatched-pattern \"src/**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}\" \"eslint.config.{js,cjs,mjs,ts,cts,mts}\" \"*.config.{js,cjs,mjs,ts,cts,mts}\" \".*rc.{js,cjs,mjs,ts,cts,mts}\"",
    "lint:fix": "eslint --fix --max-warnings=0 --no-error-on-unmatched-pattern \"src/**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}\" \"eslint.config.{js,cjs,mjs,ts,cts,mts}\" \"*.config.{js,cjs,mjs,ts,cts,mts}\" \".*rc.{js,cjs,mjs,ts,cts,mts}\"",
    "lint:staged": "lint-staged --config lint-staged.config.mjs"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.22.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/types": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.6",
    "eslint": "^9.39.4",
    "eslint-plugin-expect-type": "~0.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.1"
  }
}
