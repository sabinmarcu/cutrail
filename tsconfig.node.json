{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node", "electron"]
  },
  "include": [
    "src/cli/**/*.ts",
    "src/main/**/*.mjs",
    "src/main/**/*.ts",
    "src/preload/**/*.mjs",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "src/domain/**/*.ts",
    "src/infra/**/*.ts"
  ]
}
